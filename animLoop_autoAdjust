// duration of comp, in frames
var compDur = timeToFrames(thisComp.duration);
// loop duration, in frames
var loopDur = getNearestDivisor(compDur, effect("Loop Duration")("Slider").value);

// minimum value of loop
var minVal = effect("Minimum Value")("Slider").value;
// maximum value of loop
var maxVal = effect("Maximum Value")("Slider").value;

// main function
if (time > inPoint) {
  // whether we're looping up or down
  var descending = true;
  // where to start animation – defaults to in point of layer, as time
  var animStart = inPoint;
  // loop duration, as time
  var loopDurAsTime = framesToTime(loopDur)/2;
  // duration of hold, as time
  var holdDur = framesToTime(effect("Hold Duration")("Slider").value);
  // duration of fade, as time
  var fadeDur = loopDurAsTime - holdDur;

  if (effect ("Max to Min")("Checkbox") == True) {
  descending = true;
  } else {
  desdending = false;
  }
  
  while (time > (animStart + loopDurAsTime)) {
    animStart += loopDurAsTime;
    descending = !descending;
  }

  if (effect ("Hold Follows Animation")("Checkbox") == true) {
    holdDur *= -1;
  }

  linear(time - animStart + holdDur, loopDurAsTime - fadeDur, loopDurAsTime, descending ? maxVal : minVal, descending ? minVal : maxVal);
} else {
  maxVal;
}


/**
 * Gets nearest divisor of a number, from the starting divisor
 * If equidistant, gets nearest higher.
 * 
 * Limits to 10 loops for performance.
 *
 * @param {Number} number     Number to divide
 * @param {Number} initialDiv Initial divisor
 * @returns {Number}          Nearest divisor
 */
function getNearestDivisor(number, initialDiv) {
  var divisor = initialDiv;
  var divisorUp = divisor;
  var divisorDn = divisor;

  // Get nearest divisor
  var maxLoops = 10;
  var count = 0;
  while (number % divisor > 0) {
    count++;
    divisorUp++;
    divisorDn--;

    if (effect("Increase if Equidistant")("Checkbox") == true) {
      a = divisorUp;
      b = divisorDn;
    } else {
      a = divisorDn;
      b = divisorUp;
    }

    if (number % a === 0) divisor = a;
    else if (number % b === 0) divisor = b;

    if (count >= maxLoops)
      break;
  }

  return divisor;
}
